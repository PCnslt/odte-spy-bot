# Copy to .env and fill in what you have. NOTHING is required for paper/backtest.

# --- Interactive Brokers (only for --broker ibkr; leave blank otherwise) ---
# Host/port/client-id are set in config/config.yaml, not here. TWS or IB Gateway
# must be running with the API enabled. No username/password lives here — you log
# into TWS/Gateway yourself.
IBKR_ACCOUNT=           # optional: specific account id (e.g. DU1234567 for paper)

# --- Telegram alerts (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Hugging Face (optional, only if sentiment.enabled) ---
HF_TOKEN=

# --- Polygon.io (REQUIRED for real backtests) ---
# Needs an Options plan that includes historical option aggregates (Options Starter+).
POLYGON_API_KEY=
